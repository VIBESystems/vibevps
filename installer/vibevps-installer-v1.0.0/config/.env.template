# VIBEVps Environment Configuration

# Server
PORT=3001
HOST=0.0.0.0

# JWT Secret (auto-generated during installation)
JWT_SECRET={{JWT_SECRET}}

# Database path (SQLite)
DB_PATH=/var/www/vibevps/data/vibevps.db

# CORS Origin (set to Nginx URL in production)
CORS_ORIGIN=http://{{SERVER_IP}}:{{NGINX_PORT}}

# Encryption key for hypervisor credentials (auto-generated)
ENCRYPTION_KEY={{ENCRYPTION_KEY}}
